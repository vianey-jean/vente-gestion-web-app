# Configuration du serveur
PORT=10000
NODE_ENV=development

# URL du client (frontend)
CLIENT_URL=http://localhost:5173

# Clé secrète pour JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Clé de chiffrement pour les cartes bancaires
CARD_ENCRYPTION_KEY=your-secret-encryption-key-32-chars-long!!

# Clé Stripe (à remplacer par votre vraie clé)
# Obtenez votre clé sur: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Configuration CORS
CORS_ORIGIN=http://localhost:5173
